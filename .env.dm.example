CONTROL_DATABASE_URL=sqlite+aiosqlite:///./runtime/control.db

DM_HOME=D:\Program Files\dmdbms

DB_DIALECT=dm
DB_DRIVER=dmAsync
# 单机直连时填写 DB_HOST/DB_PORT；单位集群服务名模式建议改用 DB_SERVICE_NAME + DM_SVC_PATH
# DB_HOST=127.0.0.1
# DB_PORT=5236
DB_SERVICE_NAME=DM_CLUSTER
DM_SVC_PATH=C:\Windows\System32
DB_NAME=YOUR_DB
DB_USER=YOUR_APP_USER
DB_PASSWORD=ChangeMe_123!
AUTO_CREATE_SCHEMA=false

API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
INTERNAL_API_TOKEN=change-this-in-production
